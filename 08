Design an HTML form to collect user details (like name, email, and phone number) and 
write JavaScript code to validate the form fields before submission.


<!DOCTYPE html>
<html>
<head>
<title>Student Registration Form</title>

<script>
function validateForm() {

    let name = document.getElementById("name").value.trim();
    let username = document.getElementById("username").value.trim();
    let password = document.getElementById("password").value.trim();
    let email = document.getElementById("email").value.trim();
    let phone = document.getElementById("phone").value.trim();
    let dob = document.getElementById("dob").value;
    let course = document.getElementById("course").value;

    // Name
    if (name == "") {
        alert("Name cannot be empty");
        document.getElementById("name").focus();
        return false;
    }

    // Username
    if (username.length < 5) {
        alert("Username must be at least 5 characters");
        document.getElementById("username").focus();
        return false;
    }

    // Password
    if (password.length < 6) {
        alert("Password must be at least 6 characters");
        document.getElementById("password").focus();
        return false;
    }

    // Email
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
        alert("Enter a valid email");
        document.getElementById("email").focus();
        return false;
    }

    // Phone
    const phoneRegex = /^[0-9]{10}$/;
    if (!phoneRegex.test(phone)) {
        alert("Enter a valid 10-digit phone number");
        document.getElementById("phone").focus();
        return false;
    }

    // Gender
    let gender = document.querySelector('input[name="gender"]:checked');
    if (!gender) {
        alert("Please select gender");
        return false;
    }

    // Date of Birth
    if (dob == "") {
        alert("Please select date of birth");
        return false;
    }

    // Course
    if (course == "") {
        alert("Please select a course");
        return false;
    }

    // Subjects
    let subjects = document.querySelectorAll('input[name="subjects"]:checked');
    if (subjects.length == 0) {
        alert("Please select at least one subject");
        return false;
    }

    alert("Form submitted successfully!");
    return true;
}
</script>

</head>

<body>

<h2>Student Registration Form</h2>

<form onsubmit="return validateForm()">

Name:<br>
<input type="text" id="name"><br><br>

Username:<br>
<input type="text" id="username"><br><br>

Password:<br>
<input type="password" id="password"><br><br>

Email:<br>
<input type="text" id="email"><br><br>

Phone:<br>
<input type="text" id="phone"><br><br>

Gender:<br>
<input type="radio" name="gender" value="Male"> Male
<input type="radio" name="gender" value="Female"> Female
<input type="radio" name="gender" value="Other"> Other
<br><br>

Date of Birth:<br>
<input type="date" id="dob"><br><br>

Course:<br>
<select id="course">
    <option value="">--Select Course--</option>
    <option value="CSE">CSE</option>
    <option value="ISE">ISE</option>
    <option value="Mechanical">Mechanical</option>
    <option value="Civil">Civil</option>
    <option value="AIML">AIML</option>
</select>
<br><br>

Subjects:<br>
<input type="checkbox" name="subjects" value="Maths"> Maths
<input type="checkbox" name="subjects" value="Physics"> Physics
<input type="checkbox" name="subjects" value="Chemistry"> Chemistry
<input type="checkbox" name="subjects" value="Programming"> Programming
<input type="checkbox" name="subjects" value="Electronics"> Electronics
<br><br>

<button type="submit">Submit</button>
<button type="reset">Reset</button>

</form>

</body>
</html>
