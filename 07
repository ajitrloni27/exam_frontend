Create an HTML document using JavaScript's alert() and prompt() methods to develop a web page that:
Welcomes the user with a pop-up message, Asks for their name, and 
Displays a personalised greeting using the entered name




<!DOCTYPE html>
<html>
<head>
    <title>Program 7</title>
</head>

<body>

<h2>Welcome to JavaScript Dialogs</h2>

<script>
    alert("Welcome to the JavaScript Dialogs Demo!");

    let userName = prompt("Please enter your name:", "Guest");

    if (userName == null || userName.trim() == "") {
        alert("You did not provide a name. You will be called 'Guest'.");
        userName = "Guest";
    }

    let isReady = confirm("Hello, " + userName + "! Are you ready to proceed?");

    if (isReady) {
        alert("Great! Let's get started, " + userName + "!");
    } else {
        alert("No worries, " + userName + ". You can explore later!");
    }
</script>

</body>
</html>
