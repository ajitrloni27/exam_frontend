10. Develop an HTML page with JavaScript to: 
        • Take a number (1–10) as input, 
        • Display the Fibonacci series using a while loop,
        • Display the factorial using a do-while loop,
        • Validate the input and show the output in a styled section. 
      Use external JavaScript and apply basic CSS styling.



<!DOCTYPE html>
<html>
<head>
    <title>Program 10</title>

    <style>

      body{
        background:lightyellow;
       }

        .container {
            width: 350px;
            margin: auto;
            padding: 20px;
            border: 2px solid black;
            text-align: center;
            background:aqua;
        }
    </style>
</head>

<body>

<div class="container">

    <h2>Fibonacci and Factorial</h2>

    Enter Number (1-10):<br><br>

    <input type="number" id="num">

    <button onclick="show()">Submit</button>

    <br><br>

    <div id="output"></div>

</div>

<script>
function show() {

    let n = Number(document.getElementById("num").value);
    let output = document.getElementById("output");

    if (n < 1 || n > 10) {
        output.innerHTML = "Enter a number between 1 and 10";
        return;
    }

    let a = 0;
    let b = 1;
    let i = 1;
    let fib = "";

    while (i <= n) {
        fib = fib + a + " ";
        let c = a + b;
        a = b;
        b = c;
        i++;
    }

    let fact = 1;
    let j = 1;

    do {
        fact = fact * j;
        j++;
    } while (j <= n);

    output.innerHTML =
        "Fibonacci: " + fib +
        "<br>Factorial: " + fact;
}
</script>

</body>
</html>
</html>
